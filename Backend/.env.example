# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=clms_db
DATABASE_URL="mysql://root:your_password@localhost:3306/clms_db"

# JWT
JWT_ACCESS_SECRET=your_access_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_TTL_MINUTES=5

# Account Lock
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=30

# Rate Limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Email (Gmail)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=CLMS <your_email@gmail.com>
